---
const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Manjil Thapa Magar</title>
    <style is:global>
        :root { --font-main: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; }
        body { font-family: var(--font-main); line-height: 1.6; max-width: 800px; margin: 0 auto; padding: 2rem; background: #fafafa; color: #333; }
        nav { margin-bottom: 3rem; }
        nav a { margin-right: 1.5rem; text-decoration: none; color: #0070f3; font-weight: 500; }
        nav a:hover { text-decoration: underline; }
        h1, h2, h3 { margin-top: 2rem; }
        article { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    </style>
</head>
<body>
    <nav>
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
    </nav>
    <main>
        <slot />
    </main>
</body>
</html>
