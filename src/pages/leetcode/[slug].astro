---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PhpSandbox from '../../components/PhpSandbox.astro';

export async function getStaticPaths() {
    const posts = await getCollection('leetcode');
    return posts.map(post => ({
        params: { slug: post.id.replace(/\.md$/, '') },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Robust extraction of PHP code from Markdown (handles code blocks and blockquotes)
const extractPhpCode = (body: string) => {
    if (!body) return '';

    // 1. Check for standard Markdown code blocks first
    const codeBlockMatch = body.match(/```php([\s\S]*?)```/);
    if (codeBlockMatch) return codeBlockMatch[1].trim();

    // 2. Check for blockquote style (common in older Jekyll-style posts)
    const lines = body.split('\n');
    let inQuote = false;
    let foundSolution = false;
    const collectedLines = [];

    for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const trimmed = line.trim();

        // Start collecting if we see a blockquote start ('>') after a solution header
        // or if we see '<?php' inside a blockquote.
        if (trimmed.toLowerCase().includes('### solution')) {
            foundSolution = true;
            continue;
        }

        if (trimmed.startsWith('>') && (foundSolution || trimmed.includes('<?php') || inQuote)) {
            // If it's the first line of a blockquote and we haven't found a solution header yet,
            // we'll only start if it looks like code (e.g., contains '<?php' or 'function')
            if (!inQuote && !foundSolution && !trimmed.includes('<?php') && !trimmed.includes('function') && !trimmed.includes('$')) {
                continue;
            }

            inQuote = true;
            // Remove the '>' and handle potential leading spaces
            const content = line.replace(/^\s*>\s?/, '');
            collectedLines.push(content);
        } else if (inQuote && trimmed === '') {
            // Keep empty lines within the quote
            collectedLines.push('');
        } else if (inQuote) {
            // End of the blockquote section
            // But if we only have one or two lines, it might just be a regular quote.
            // Let's check if we actually found something that looks like code.
            const fullText = collectedLines.join('\n');
            if (fullText.includes('<?php') || fullText.includes('function') || fullText.includes('class') || fullText.includes('$')) {
                break;
            } else {
                // Not code, reset and keep looking
                inQuote = false;
                collectedLines.length = 0;
            }
        }
    }

    if (collectedLines.length > 0) {
        let code = collectedLines.join('\n').trim();
        // Ensure it starts with <?php for the WASM engine
        if (!code.startsWith('<?php')) {
            code = '<?php\n' + code;
        }
        return code;
    }

    return '';
};

const extractedCode = extractPhpCode(post.body || '');

const formatDate = (date: Date | undefined) => {
    if (!date) return '';
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
};
---
<Layout title={post.data.title || post.id.replace(/\.md$/, '').replace(/-/g, ' ')}>
    <article class="prose">
        <header>
            <a href="/leetcode" class="back-link">cd ../.. // BACK_TO_LEETCODE</a>
            <h1>{post.data.title || post.id.replace(/\.md$/, '').replace(/-/g, ' ')}</h1>
            <div class="post-metadata">
                <span class="date">TIMESTAMP: {formatDate(post.data.date)}</span>
                {post.data.tags && (
                    <div class="tags">
                        {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
                    </div>
                )}
            </div>
        </header>
        
        <div class="content">
            <Content />
        </div>

        {extractedCode && (
            <div class="solution-sandbox-wrapper fade-in delay-3">
                <PhpSandbox 
                    id={`leetcode-${post.id.replace(/\.md$/, '')}`}
                    title="Interactive Solution Console"
                    initialCode={extractedCode}
                    description="Run the PHP solution above directly in your browser. Feel free to modify the test cases!"
                />
            </div>
        )}
    </article>
</Layout>

<style is:global>
    /* Matrix theme typography for the rendered content */
    .prose .content {
        color: var(--text-color);
        font-size: 1.1rem;
        line-height: 1.8;
    }
    
    .prose .content h1, .prose .content h2, .prose .content h3 {
        margin-top: 2.5rem;
        margin-bottom: 1.25rem;
        border: none;
        line-height: 1.3;
        color: var(--accent-color);
        text-transform: uppercase;
        text-shadow: 0 0 10px rgba(0, 255, 65, 0.3);
    }
    
    .prose .content a { color: var(--accent-color); text-decoration: underline; text-underline-offset: 4px; }
    
    .prose .content pre {
        background-color: #000000 !important;
        padding: 1.5rem;
        border-radius: 0;
        overflow-x: auto;
        margin: 2.5rem 0;
        border: 1px solid var(--border-color);
    }

    .prose .content blockquote {
        border-left: 4px solid var(--accent-color);
        padding: 0.5rem 0 0.5rem 1.5rem;
        margin: 2rem 0;
        color: var(--secondary-text);
        font-style: italic;
        background-color: rgba(0, 59, 0, 0.05);
        border-radius: 0;
    }

    .prose .content ul, .prose .content ol {
        margin: 1.5rem 0;
        padding-left: 1.5rem;
        list-style-type: "> ";
    }

    .prose .content li {
        margin-bottom: 0.75rem;
    }

    .prose .content strong { color: var(--accent-color); }

    /* Fix for nested sandbox styling */
    .solution-sandbox-wrapper {
        margin-top: 5rem;
        border-top: 2px solid var(--accent-color);
        padding-top: 2rem;
    }
</style>

<style>
    .prose {
        background-color: rgba(0, 59, 0, 0.02);
        padding: 4rem;
        border-radius: 0;
        border: 1px solid var(--border-color);
        max-width: 100%;
    }
    
    @media (max-width: 640px) {
        .prose { padding: 2rem; }
    }

    header { margin-bottom: 4rem; }
    
    .back-link {
        display: inline-block;
        margin-bottom: 2rem;
        color: var(--accent-color);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .back-link:hover { text-shadow: 0 0 8px var(--accent-color); transform: translateX(-5px); }
    
    h1 {
        font-size: 3rem;
        margin: 0;
        line-height: 1.1;
        font-weight: 800;
        border: none;
        text-shadow: 0 0 20px rgba(0, 255, 65, 0.4);
        text-transform: uppercase;
    }

    .post-metadata {
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        border-top: 1px solid var(--border-color);
        padding-top: 1.5rem;
    }

    .date {
        color: var(--secondary-text);
        font-weight: 700;
        font-size: 0.85rem;
    }

    .tags {
        display: flex;
        gap: 1rem;
    }

    .tag {
        color: var(--accent-color);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
</style>
