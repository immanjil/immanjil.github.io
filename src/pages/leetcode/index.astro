---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const selectedTag = Astro.url.searchParams.get('tag');

const allPosts = await getCollection('leetcode');
const posts = allPosts
    .filter(post => !selectedTag || post.data.tags?.includes(selectedTag))
    .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

const formatDate = (date: Date | undefined) => {
    if (!date) return '';
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
};
---
<Layout title="LeetCode Problems">
    <div class="blog-header">
        <h1>LeetCode Problems</h1>
        <p>A monthly series exploring algorithmic challenges and solutions.</p>
        {selectedTag && (
            <div class="filter-info">
                Showing problems tagged with <span class="active-tag">#{selectedTag}</span>
                <a href="/leetcode" class="clear-filter">Clear Filter</a>
            </div>
        )}
    </div>
    
    <div class="posts-list">
        {posts.map(post => (
            <article class="post-item">
                <div class="post-meta">
                    <span class="post-date">{formatDate(post.data.date)}</span>
                    {post.data.tags && (
                        <div class="post-tags">
                            {post.data.tags.map(tag => (
                                <a href={`/leetcode?tag=${tag}`} class={`tag ${selectedTag === tag ? 'active' : ''}`}>
                                    #{tag}
                                </a>
                            ))}
                        </div>
                    )}
                </div>
                <a href={`/leetcode/${post.id.replace(/\.md$/, '')}`} class="post-link">
                    <h2>{post.data.title || post.id.replace(/\.md$/, '').replace(/-/g, ' ')}</h2>
                    <p>Read more →</p>
                </a>
            </article>
        ))}
    </div>
</Layout>

<style>
    .blog-header { margin-bottom: 4rem; margin-top: 2rem; }
    .blog-header p { color: var(--secondary-text); font-size: 1.25rem; margin-bottom: 1.5rem; }
    
    .filter-info {
        font-size: 1rem;
        color: var(--secondary-text);
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--card-bg);
        padding: 0.75rem 1.25rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        width: fit-content;
    }

    .active-tag { color: var(--accent-color); font-weight: 700; }
    .clear-filter { color: var(--secondary-text); text-decoration: underline; font-size: 0.9rem; }
    .clear-filter:hover { color: var(--accent-color); }

    .posts-list { display: grid; gap: 2rem; }
    
    .post-item {
        padding: 2.5rem;
        border-radius: 12px;
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        transition: transform 0.2s, border-color 0.2s;
    }
    
    .post-item:hover {
        transform: translateY(-4px);
        border-color: var(--accent-color);
    }
    
    .post-link { text-decoration: none; color: inherit; }
    
    .post-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .post-date {
        font-size: 0.9rem;
        color: var(--secondary-text);
        font-weight: 500;
    }

    .post-tags {
        display: flex;
        gap: 0.75rem;
    }

    .tag {
        font-size: 0.8rem;
        color: var(--secondary-text);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-decoration: none;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .tag:hover, .tag.active {
        color: var(--accent-color);
        background: rgba(0, 112, 243, 0.05);
    }

    .post-item h2 { margin: 0; font-size: 1.75rem; text-transform: capitalize; border: none; }
    .post-item p { margin-top: 1.5rem; color: var(--accent-color); font-weight: 600; }
</style>
