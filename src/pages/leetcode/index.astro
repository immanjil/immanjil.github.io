---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('leetcode')).sort(
    (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);

const formatDate = (date: Date | undefined) => {
    if (!date) return '';
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
};
---
<Layout title="LeetCode Problems">
    <div class="blog-header">
        <h1>LeetCode Problems</h1>
        <p>A monthly series exploring algorithmic challenges and solutions.</p>
    </div>
    
    <div class="posts-list">
        {posts.map(post => (
            <article class="post-item">
                <a href={`/leetcode/${post.id}`}>
                    <div class="post-meta">
                        <span class="post-date">{formatDate(post.data.date)}</span>
                        {post.data.tags && (
                            <div class="post-tags">
                                {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
                            </div>
                        )}
                    </div>
                    <h2>{post.data.title || post.id.replace(/-/g, ' ')}</h2>
                    <p>Read more →</p>
                </a>
            </article>
        ))}
    </div>
</Layout>

<style>
    .blog-header { margin-bottom: 4rem; margin-top: 2rem; }
    .blog-header p { color: var(--secondary-text); font-size: 1.25rem; }
    
    .posts-list { display: grid; gap: 2rem; }
    
    .post-item {
        padding: 2.5rem;
        border-radius: 12px;
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        transition: transform 0.2s, border-color 0.2s;
    }
    
    .post-item:hover {
        transform: translateY(-4px);
        border-color: var(--accent-color);
    }
    
    .post-item a { text-decoration: none; color: inherit; }
    
    .post-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .post-date {
        font-size: 0.9rem;
        color: var(--secondary-text);
        font-weight: 500;
    }

    .post-tags {
        display: flex;
        gap: 0.75rem;
    }

    .tag {
        font-size: 0.8rem;
        color: var(--accent-color);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .post-item h2 { margin: 0; font-size: 1.75rem; text-transform: capitalize; border: none; }
    .post-item p { margin-top: 1.5rem; color: var(--accent-color); font-weight: 600; }
</style>
