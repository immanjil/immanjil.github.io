---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
import ExperienceCard from '../components/ExperienceCard.astro';
import SkillBadge from '../components/SkillBadge.astro';
import { getCollection } from 'astro:content';

const systemDesignPosts = await getCollection('system-design');
const leetcodePosts = await getCollection('leetcode');

// Get latest from each
const latestSystemDesign = systemDesignPosts
    .sort((a, b) => new Date(b.data.pubDate || b.data.date || 0).getTime() - new Date(a.data.pubDate || a.data.date || 0).getTime())
    .slice(0, 1);

const latestLeetcode = leetcodePosts
    .sort((a, b) => new Date(b.data.pubDate || b.data.date || 0).getTime() - new Date(a.data.pubDate || a.data.date || 0).getTime())
    .slice(0, 2);

const latestProject = profile.projects
    .sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime())
    .slice(0, 1);
---

<Layout title="Home">
    <section class="intro fade-in">
        <div class="intro-content">
            <div class="intro-text">
                <h1>{profile.name}</h1>
                <p class="title">{profile.title} @ {profile.company}</p>
                <p class="bio">{profile.intro}</p>
            </div>
            {profile.links.avatar && (
                <div class="profile-image-container">
                    <img src={profile.links.avatar} alt={profile.name} class="profile-image" />
                </div>
            )}
        </div>
        <div class="social-links">
            <a href={profile.links.linkedin} target="_blank" aria-label="LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                <span>LinkedIn</span>
            </a>
            <a href={profile.links.github} target="_blank" aria-label="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                <span>GitHub</span>
            </a>
            <a href={profile.links.resume} target="_blank" class="resume-button">Download Resume</a>
        </div>
    </section>

    <section class="at-a-glance fade-in delay-1">
        <div class="stat-card">
            <span class="stat-value">9+</span>
            <span class="stat-label">Years Experience</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">6+</span>
            <span class="stat-label">Engineers Managed</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">TX</span>
            <span class="stat-label">Based (Frisco/Dallas)</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">AI</span>
            <span class="stat-label">Agentic Orchestration</span>
        </div>
    </section>

    <section id="latest-insights" class="fade-in delay-2">
        <div class="section-header">
            <h2>Latest Insights</h2>
            <div class="header-links">
                <a href="/projects">Projects</a>
                <a href="/system-design">System Design</a>
                <a href="/leetcode">LeetCode</a>
            </div>
        </div>
        <div class="insights-grid">
            {latestProject.map(project => (
                <a href={project.link} class="insight-card featured">
                    <span class="category">Featured Project</span>
                    <h3>{project.title}</h3>
                    <p>{project.description}</p>
                    <div class="tech-stack-mini">
                        {project.tech.slice(0, 3).map(t => <span class="tech-tag">{t}</span>)}
                    </div>
                    <span class="read-more">View Project Details →</span>
                </a>
            ))}
            {latestSystemDesign.map(post => (
                <a href={`/system-design/${post.id.replace(/\.md$/, '')}`} class="insight-card">
                    <span class="category">System Design</span>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <span class="read-more">Read Architecture →</span>
                </a>
            ))}
            {latestLeetcode.map(post => (
                <a href={`/leetcode/${post.id.replace(/\.md$/, '')}`} class="insight-card">
                    <span class="category">LeetCode</span>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <span class="read-more">View Solution →</span>
                </a>
            ))}
        </div>
    </section>

    <section id="experience" class="fade-in delay-3">
        <h2>Professional Experience</h2>
        {profile.experience.map(exp => (
            <ExperienceCard {...exp} />
        ))}
    </section>

    <section id="skills">
        <h2>Technical Skills</h2>
        <div class="skills-category">
            <h3>Programming Languages</h3>
            <div class="badges">
                {profile.skills.languages.map(skill => <SkillBadge name={skill} />)}
            </div>
            
            <h3>Frameworks</h3>
            <div class="badges">
                {profile.skills.frameworks.map(skill => <SkillBadge name={skill} />)}
            </div>

            <h3>Databases & Cloud</h3>
            <div class="badges">
                {profile.skills.backend.map(skill => <SkillBadge name={skill} />)}
            </div>

            <h3>Tools & Specialties</h3>
            <div class="badges">
                {profile.skills.tools.map(skill => <SkillBadge name={skill} />)}
            </div>
        </div>
    </section>

    <section id="education">
        <h2>Education</h2>
        <div class="education-card">
            <h3>{profile.education.degree}</h3>
            <p>{profile.education.college} | {profile.education.period}</p>
        </div>
    </section>
</Layout>

<style>
    .intro { margin-bottom: 6rem; margin-top: 2rem; }
    .intro-content { display: flex; align-items: flex-start; gap: 3rem; justify-content: space-between; }
    .intro-text { flex: 1; }
    
    .profile-image-container {
        flex-shrink: 0;
        width: 200px;
        height: 200px;
        border-radius: 20px;
        overflow: hidden;
        border: 4px solid var(--card-bg);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        transform: rotate(2deg);
        transition: transform 0.3s ease;
    }

    .profile-image-container:hover {
        transform: rotate(0deg) scale(1.05);
    }

    .profile-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (max-width: 768px) {
        .intro-content { flex-direction: column-reverse; gap: 2rem; }
        .profile-image-container { width: 150px; height: 150px; margin-bottom: 1rem; }
    }

    h1 { font-size: 3.5rem; margin-bottom: 0.5rem; line-height: 1.1; font-weight: 800; }
    .title { font-size: 1.5rem; color: var(--secondary-text); font-weight: 600; margin-bottom: 1.5rem; }
    .bio { font-size: 1.25rem; color: var(--text-color); max-width: 700px; line-height: 1.6; opacity: 0.9; }
    
    .social-links { margin-top: 2.5rem; display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
    .social-links a { 
        font-weight: 600; 
        color: var(--text-color); 
        text-decoration: none; 
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .social-links a:hover { color: var(--accent-color); }
    .social-links svg { opacity: 0.8; }
    .social-links a:hover svg { opacity: 1; stroke: var(--accent-color); }
    
    .resume-button {
        background-color: var(--text-color);
        color: var(--bg-color) !important;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        transition: transform 0.2s, opacity 0.2s;
    }
    .resume-button:hover {
        transform: scale(1.05);
        opacity: 0.9;
    }

    .at-a-glance {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-top: -2rem;
        margin-bottom: 6rem;
    }

    @media (min-width: 768px) {
        .at-a-glance {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .stat-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        padding: 1.5rem;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition: border-color 0.2s;
    }

    .stat-card:hover {
        border-color: var(--accent-color);
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--accent-color);
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .stat-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--secondary-text);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    section { margin-top: 6rem; }
    h2 { font-size: 2rem; font-weight: 700; margin-bottom: 3rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 0.5rem;
    }

    .section-header h2 {
        margin: 0;
        border: none;
        padding: 0;
    }

    .header-links {
        display: flex;
        gap: 1.5rem;
    }

    .header-links a {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--accent-color);
        text-decoration: none;
    }

    .header-links a:hover {
        text-decoration: underline;
    }

    .insights-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .insights-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .insight-card {
        background: rgba(0, 38, 0, 0.1);
        border: 1px solid var(--border-color);
        padding: 2rem;
        border-radius: 4px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .insight-card:hover {
        border-color: var(--accent-color);
        box-shadow: 0 0 12px rgba(0, 204, 51, 0.15);
        background: rgba(0, 204, 51, 0.03);
    }

    .insight-card::before {
        content: "> ";
        position: absolute;
        top: 2rem;
        left: 1rem;
        color: var(--accent-color);
        opacity: 0;
        transition: opacity 0.2s;
    }

    .insight-card:hover::before {
        opacity: 1;
    }

    .insight-card:hover h3 {
        transform: translateX(1.5rem);
    }

    .insight-card.featured {
        border-left: 4px solid var(--accent-color);
    }

    .insight-card .category {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-color);
        margin-bottom: 1rem;
    }

    .insight-card h3 {
        margin: 0 0 1rem 0;
        font-size: 1.4rem;
        line-height: 1.2;
        transition: transform 0.3s ease;
    }

    .insight-card p {
        font-size: 1rem;
        color: var(--secondary-text);
        margin: 0 0 2rem 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    .tech-stack-mini {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .tech-tag {
        font-size: 0.7rem;
        background: var(--bg-color);
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        color: var(--secondary-text);
        border: 1px solid var(--border-color);
    }

    .read-more {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--accent-color);
    }
    
    .skills-category h3 { 
        margin-top: 2.5rem; 
        margin-bottom: 1.25rem; 
        color: var(--secondary-text); 
        font-size: 1rem; 
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .badges { display: flex; flex-wrap: wrap; }

    .education-card h3 { color: var(--text-color); margin-top: 0; font-size: 1.4rem; }
    .education-card p { color: var(--secondary-text); font-weight: 500; }

    /* Theme Toggle Icons */
    :global(.dark) .sun { display: none; }
    :global(.dark) .moon { display: inline; }
    .sun { display: inline; }
    .moon { display: none; }
</style>
