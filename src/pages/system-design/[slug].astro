---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const posts = await getCollection('system-design');
    return posts.map(post => ({
        params: { slug: post.id.replace(/\.md$/, '') },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date | undefined) => {
    if (!date) return '';
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
};
---
<Layout title={post.data.title || post.id.replace(/\.md$/, '').replace(/-/g, ' ')}>
    <article class="prose">
        <header>
            <a href="/system-design" class="back-link">cd .. // BACK_TO_SYSTEM_DESIGN</a>
            <h1>{post.data.title || post.id.replace(/\.md$/, '').replace(/-/g, ' ')}</h1>
            <div class="post-metadata">
                <span class="date">TIMESTAMP: {formatDate(post.data.date)}</span>
                {post.data.tags && (
                    <div class="tags">
                        {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
                    </div>
                )}
            </div>
        </header>
        <div class="content">
            <Content />
        </div>
    </article>
</Layout>

<style is:global>
    .prose .content {
        color: var(--text-color);
        font-size: 1.1rem;
        line-height: 1.8;
    }
    
    .prose .content h1, .prose .content h2, .prose .content h3 {
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        border: none;
        line-height: 1.3;
        font-weight: 800;
        color: var(--accent-color);
        text-shadow: 0 0 10px rgba(0, 255, 65, 0.3);
        text-transform: uppercase;
    }

    .prose .content h2 { font-size: 1.75rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    .prose .content h3 { font-size: 1.4rem; }
    
    .prose .content a { color: var(--accent-color); text-decoration: underline; text-underline-offset: 4px; }
    .prose .content a:hover { text-shadow: 0 0 8px var(--accent-color); }
    
    .prose .content pre {
        background-color: #000000 !important;
        padding: 1.5rem;
        border-radius: 0;
        overflow-x: auto;
        margin: 2.5rem 0;
        border: 1px solid var(--border-color);
        box-shadow: inset 0 0 15px rgba(0, 255, 65, 0.05);
    }

    .prose .content blockquote {
        border-left: 4px solid var(--accent-color);
        padding: 1rem 0 1rem 1.5rem;
        margin: 2rem 0;
        color: var(--secondary-text);
        font-style: italic;
        background-color: rgba(0, 59, 0, 0.05);
        border-radius: 0;
    }

    .prose .content ul, .prose .content ol {
        margin: 1.5rem 0;
        padding-left: 1.5rem;
        list-style-type: "> ";
    }

    .prose .content li {
        margin-bottom: 0.75rem;
    }

    .prose .content strong { color: var(--accent-color); font-weight: 700; text-shadow: 0 0 5px rgba(0, 255, 65, 0.2); }
</style>

<style>
    .prose {
        background-color: rgba(0, 59, 0, 0.02);
        padding: 4rem;
        border-radius: 0;
        border: 1px solid var(--border-color);
        max-width: 100%;
        box-shadow: 0 0 30px rgba(0, 255, 65, 0.02);
    }
    
    @media (max-width: 640px) {
        .prose { padding: 2rem; }
    }

    header { margin-bottom: 4rem; }
    
    .back-link {
        display: inline-block;
        margin-bottom: 2rem;
        color: var(--accent-color);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .back-link:hover { text-shadow: 0 0 8px var(--accent-color); transform: translateX(-5px); }
    
    h1 {
        font-size: 3rem;
        margin: 0;
        line-height: 1.1;
        font-weight: 800;
        border: none;
        text-shadow: 0 0 20px rgba(0, 255, 65, 0.4);
        text-transform: uppercase;
    }

    .post-metadata {
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        border-top: 1px solid var(--border-color);
        padding-top: 1.5rem;
    }

    .date {
        color: var(--secondary-text);
        font-weight: 700;
        font-size: 0.85rem;
    }

    .tags {
        display: flex;
        gap: 1rem;
    }

    .tag {
        color: var(--accent-color);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
</style>
