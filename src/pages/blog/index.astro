---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
---
<Layout title="Blog">
    <h1>Blog</h1>
    <ul>
        {posts.map(post => (
            <li>
                <a href={`/blog/${post.id}`}>{post.id.replace(/-/g, ' ')}</a>
            </li>
        ))}
    </ul>
</Layout>
