---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
---
<Layout title="Blog">
    <div class="blog-header">
        <h1>Blog</h1>
        <p>Thoughts on engineering, leadership, and AI.</p>
    </div>
    
    <div class="posts-list">
        {posts.map(post => (
            <article class="post-item">
                <a href={`/blog/${post.id}`}>
                    <h2>{post.id.replace(/-/g, ' ')}</h2>
                    <p>Read more →</p>
                </a>
            </article>
        ))}
    </div>
</Layout>

<style>
    .blog-header { margin-bottom: 4rem; margin-top: 2rem; }
    .blog-header p { color: var(--secondary-text); font-size: 1.25rem; }
    
    .posts-list { display: grid; gap: 2rem; }
    
    .post-item {
        padding: 2rem;
        border-radius: 12px;
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        transition: transform 0.2s, border-color 0.2s;
    }
    
    .post-item:hover {
        transform: translateY(-4px);
        border-color: var(--accent-color);
    }
    
    .post-item a { text-decoration: none; color: inherit; }
    .post-item h2 { margin: 0; font-size: 1.5rem; text-transform: capitalize; border: none; }
    .post-item p { margin-top: 1rem; color: var(--accent-color); font-weight: 600; }
</style>
