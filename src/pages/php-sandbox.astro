---
import Layout from '../layouts/Layout.astro';
import PhpSandbox from '../components/PhpSandbox.astro';

const twoSumSolution = `<?php
class Solution {
    /**
     * @param Integer[] $nums
     * @param Integer $target
     * @return Integer[]
     */
    function twoSum($nums, $target) {
        $map = [];
        foreach ($nums as $i => $num) {
            $complement = $target - $num;
            if (isset($map[$complement])) {
                return [$map[$complement], $i];
            }
            $map[$num] = $i;
        }
        return [];
    }
}
?>`;

const twoSumBruteForce = `<?php
class Solution {
    /**
     * @param Integer[] $nums
     * @param Integer $target
     * @return Integer[]
     */
    function twoSum($nums, $target) {
        $n = count($nums);
        for ($i = 0; $i < $n; $i++) {
            for ($j = $i + 1; $j < $n; $j++) {
                if ($nums[$i] + $nums[$j] === $target) {
                    return [$i, $j];
                }
            }
        }
        return [];
    }
}
?>`;

const twoSumTwoPointer = `<?php
class Solution {
    /**
     * Note: This approach requires sorting.
     */
    function twoSum($nums, $target) {
        sort($nums);
        $left = 0;
        $right = count($nums) - 1;
        while ($left < $right) {
            $sum = $nums[$left] + $nums[$right];
            if ($sum === $target) return [$nums[$left], $nums[$right]];
            if ($sum < $target) $left++;
            else $right--;
        }
        return [];
    }
}
?>`;

const altSolutions = [
    { label: "Brute Force", code: twoSumBruteForce },
    { label: "Two-Pointer", code: twoSumTwoPointer }
];

const twoSumTests = `// Test Cases for Two Sum
$sol = new Solution();

$testCases = [
    ['nums' => [2, 7, 11, 15], 'target' => 9],
    ['nums' => [3, 2, 4], 'target' => 6],
    ['nums' => [3, 3], 'target' => 6]
];

foreach ($testCases as $i => $test) {
    $result = $sol->twoSum($test['nums'], $test['target']);
    echo "Test Case " . ($i + 1) . ":\\n";
    echo "Input: nums = [" . implode(", ", $test['nums']) . "], target = " . $test['target'] . "\\n";
    echo "Output: [" . implode(", ", $result) . "]\\n\\n";
}
`;
---

<Layout title="PHP Sandbox" isFullWidth={true}>
    <div class="sandbox-page-container fade-in">
        <header class="page-header">
            <div class="breadcrumb">SYSTEM_TOOLS // PHP_INTERPRETER // WASM_RUNTIME</div>
            <h1>PHP Interactive Sandbox</h1>
            <p>Write and run PHP code directly in your browser. Powered by WebAssembly.</p>
        </header>

        <div class="sandbox-wrapper">
            <PhpSandbox 
                initialCode={twoSumSolution} 
                solutions={altSolutions}
                testCaseInitialCode={twoSumTests}
                id="main-sandbox" 
                title="PHP 8.x Environment (Two Sum Example)"
                description="Experiment with PHP code snippets locally. No data is sent to the server. Your code runs in a secure WebAssembly sandbox."
            />
        </div>
    </div>

    <style>
        .sandbox-page-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .page-header {
            margin-bottom: 2.5rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 1.5rem;
        }

        .breadcrumb {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: var(--secondary-text);
            margin-bottom: 1rem;
            letter-spacing: 0.1em;
        }

        h1 {
            font-size: 2.5rem;
            margin: 0 0 0.5rem 0;
            color: var(--accent-color);
        }

        .page-header p {
            color: var(--secondary-text);
            font-size: 1rem;
            margin: 0;
        }

        .sandbox-wrapper {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 12px;
            padding: 0.5rem;
        }

        @media (max-width: 768px) {
            h1 { font-size: 2rem; }
        }
    </style>
</Layout>
