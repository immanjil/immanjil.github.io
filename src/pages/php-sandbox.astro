---
import Layout from '../layouts/Layout.astro';
import PhpSandbox from '../components/PhpSandbox.astro';

const defaultCode = `<?php
// PHP Sandbox powered by WebAssembly (php-wasm)
echo "Hello, world! Today is " . date('l, F j, Y') . "\\n";

$numbers = [1, 2, 3, 4, 5];
$squared = array_map(fn($n) => $n * $n, $numbers);

echo "Squared numbers: " . implode(', ', $squared) . "\\n";

function greet($name) {
    return "Greetings, " . $name . "!\\n";
}

echo greet("Manjil");
?>`;
---

<Layout title="PHP Sandbox">
    <div class="sandbox-page-container fade-in">
        <header class="page-header">
            <h1>PHP Sandbox</h1>
            <p>Write and run PHP code directly in your browser using WebAssembly.</p>
        </header>

        <PhpSandbox 
            initialCode={defaultCode} 
            id="main-sandbox" 
            title="Interactive PHP Environment"
            description="Experiment with PHP code snippets locally. No data is sent to the server."
        />
    </div>

    <style>
        .sandbox-page-container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .page-header {
            margin-bottom: 3rem;
        }

        .page-header p {
            color: var(--secondary-text);
            font-size: 1.1rem;
        }
    </style>
</Layout>
