---
const { role, company, period, description } = Astro.props;
---
<div class="experience-card">
    <div class="header">
        <h3>{role}</h3>
        <span class="period">[{period}]</span>
    </div>
    <div class="company">> {company}</div>
    <p class="description">{description}</p>
</div>

<style>
    .experience-card {
        margin-bottom: 3rem;
        padding: 1.5rem;
        border: 1px solid var(--border-color);
        background: rgba(0, 59, 0, 0.05);
        position: relative;
    }
    
    .experience-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: var(--accent-color);
        box-shadow: 0 0 10px var(--accent-color);
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.5rem;
    }
    
    h3 { margin: 0; color: var(--text-color); font-weight: 700; font-size: 1.3rem; text-transform: uppercase; }
    .period { font-size: 0.85rem; color: var(--secondary-text); font-weight: 600; }
    .company { font-weight: 700; color: var(--accent-color); margin-top: 0.2rem; font-size: 1.1rem; }
    .description { margin-top: 1rem; color: var(--text-color); opacity: 0.9; line-height: 1.7; }
</style>
