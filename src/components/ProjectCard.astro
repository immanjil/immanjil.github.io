---
const { title, description, tech, link } = Astro.props;
import SkillBadge from './SkillBadge.astro';
---
<a href={link} target="_blank" class="project-card">
    <div class="header">
        <h3>{title}</h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="link-icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </div>
    <p>{description}</p>
    <div class="tech-stack">
        {tech.map((t: string) => <SkillBadge name={t} />)}
    </div>
</a>

<style>
    .project-card {
        padding: 2rem;
        border: 1px solid var(--border-color);
        background-color: var(--card-bg);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        border-color: var(--accent-color);
    }
    .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }
    h3 { margin: 0; color: var(--text-color); font-size: 1.3rem; }
    .link-icon { color: var(--secondary-text); transition: color 0.2s; }
    .project-card:hover .link-icon { color: var(--accent-color); }
    p { color: var(--secondary-text); font-size: 0.95rem; line-height: 1.5; flex-grow: 1; margin-bottom: 2rem; }
    .tech-stack { display: flex; flex-wrap: wrap; margin-bottom: -0.75rem; }
</style>
